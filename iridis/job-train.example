#!/bin/bash
#SBATCH --job-name=<PKG_NAME>
#SBATCH --partition=ecsstudents_l4
#SBATCH --account=ecsstudents
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=16
#SBATCH --gres=gpu:2
#SBATCH --mem=128G
#SBATCH --time=24:00:00
#SBATCH --mail-type=ALL
#SBATCH --mail-user=your_email@example.com
################################################################################
# SLURM Job Script Template for Iridis X -- TRAINING
#
# This is the TRAINING template. Siblings:
#   job-eval.example      -- Evaluation jobs (single GPU, reads existing ckpts)
#   job-analysis.example  -- Mechanistic analysis jobs (single GPU, reads ckpts,
#                            writes structured outputs to run_N/)
#
# For cluster access, env setup, GPU partitions, submission and monitoring,
# see the QuickStart section of README.md. This template only covers the
# training-job-specific fill-in-the-blanks.
#
# HOW TO USE:
#   1. Copy this file into your package directory:
#        cp iridis/job-train.example iridis/<your-package>/job.sh
#   2. Replace every <PKG_NAME> with your package directory name,
#      <MODEL_NAME> with your model class from models/__init__.py
#   3. Fill in the CONFIGURATION section (architecture, hyperparams)
#   4. Adjust SBATCH resources (GPU count, memory, time) for your workload
#   5. Run from the repo root:
#        cd ~/CoTFormer && bash iridis/<your-package>/job.sh
#
# SELF-SUBMITTING: Running with `bash` (not `sbatch`) auto-creates a run_N
# log directory and submits via sbatch. Resubmit to auto-resume from the
# latest checkpoint (requires --use_pretrained auto, set below).
#
# ==============================================================================
# CHECKPOINT PATH CONVENTION (single source of truth)
# ==============================================================================
# main.py constructs the checkpoint path INTERNALLY from CLI flags:
#
#     ckpt_path = results_base_folder / dataset / model / exp_name
#
# and creates it via os.makedirs on rank 0. Job scripts pass EXPS_DIR (via
# --results_base_folder), <MODEL_NAME> (via --model), and EXP_NAME (via
# --exp_name) as flags. main.py handles directory creation itself.
#
# DO NOT mirror that formula in bash with a CKPT_DIR variable. bash/Python
# path mirrors inevitably drift; when they do, bash creates a ghost directory
# and Python writes to a different location. The lncot-train and adm-train
# packages are the canonical pattern: no bash path-construction, just flags.
# See docs/reprod-notes.md §C4 for the full case study.
#
# TEAMMATE COLLISIONS: if your --model value is shared with a teammate on
# scratch (e.g. `cotformer_full_depth`), your EXP_NAME must be distinctive
# enough to land in a leaf dir they haven't touched. If os.makedirs fails
# with PermissionError, the fix is social (ask them to chmod g+w the parent)
# or by renaming your EXP_NAME, NEVER by adding a bash CKPT_DIR workaround.
# ==============================================================================
################################################################################

# ========================= CONFIGURATION ======================================
# Adjust these to match your --gres and architecture choices.

N_GPUS=2          # Must match --gres=gpu:N above (max 2 on ecsstudents_l4)
N_LAYER=24        # Total transformer layers
N_REPEAT=5        # Number of block repeats
ITERATIONS=40000  # Training steps
BATCH_SIZE=8      # Per-GPU micro-batch (L4 24GB is tight -- start conservative)
ACC_STEPS=16      # Gradient accumulation (DDP halves per GPU, x N_GPUS -> cancels)
                  # Effective batch size = BATCH_SIZE * ACC_STEPS (always, regardless of N_GPUS)
CKPT_FREQ=2000    # Save checkpoint every N steps
SEED=0            # Random seed (change for multi-seed runs)

# Reserved layers (prefix/suffix not repeated).
# Set both to 0 for Table 1 (base CoTFormer, no reserved layers).
# Set to 2/1 for Table 2 (LN-CoTFormer with reserved layers).
N_LAYER_BEGIN=2
N_LAYER_END=1

# ========================= END CONFIGURATION ==================================

# --- Self-submitting wrapper (runs on login node) ---
if [ -z "$SLURM_JOB_ID" ]; then
    PACKAGE_DIR="$(cd "$(dirname "$0")" && pwd)"
    REPO_DIR="$(cd "$PACKAGE_DIR/../.." && pwd)"
    source "$REPO_DIR/iridis/env.sh"

    RUN_DIR=$(next_run_dir "$PACKAGE_DIR")
    echo "=== <PKG_NAME> Training ==="
    echo "  Partition: ecsstudents_l4"
    echo "  GPUs:      $N_GPUS"
    echo "  Layers:    $N_LAYER (${N_LAYER_BEGIN}+mid*${N_REPEAT}+${N_LAYER_END})"
    echo "  Steps:     $ITERATIONS"
    echo "  Eff. BS:   $((BATCH_SIZE * ACC_STEPS))"
    echo "  Seed:      $SEED"
    echo "  Logs:      $RUN_DIR/"
    echo ""
    exec sbatch \
        --output="$RUN_DIR/slurm_%j.out" \
        --error="$RUN_DIR/slurm_%j.err" \
        --mail-type=BEGIN,END,FAIL \
        --mail-user="$NOTIFY_EMAIL" \
        --export=ALL,REPO_DIR="$REPO_DIR" \
        "$0" "$@"
fi

# --- Actual job (runs on compute node) ---
set -eo pipefail
export PYTHONUNBUFFERED=1

# REPO_DIR passed by self-submitting wrapper via --export
if [ -z "$REPO_DIR" ]; then
    REPO_DIR="$HOME/CoTFormer"
    echo "WARNING: REPO_DIR not set -- falling back to $REPO_DIR"
    echo "Tip: use 'bash job.sh' instead of 'sbatch job.sh'"
fi

source "$REPO_DIR/iridis/env.sh"

# --- Scratch-based output dirs (off home quota) ---
# See the "CHECKPOINT PATH CONVENTION" block at the top of this file. main.py
# constructs and creates the ckpt_path itself from --results_base_folder,
# --model, --exp_name (and --dataset). We only create EXPS_DIR here (and
# the data/cache/wandb siblings) — NOT the full ckpt path.
EXPS_DIR="/scratch/$USER/exps"
# EXP_NAME is the LEAF dir name (last segment of ckpt_path). Used only in
# --exp_name below and in echoes. MUST be stable across resubmissions for
# --use_pretrained auto to resume correctly.
EXP_NAME="<MODEL_NAME>_lr0.001_bs${BATCH_SIZE}x${ACC_STEPS}_seqlen256_seed${SEED}"
mkdir -p "$EXPS_DIR" "$DATA_DIR" "$HF_HOME" "$TIKTOKEN_CACHE_DIR" "$WANDB_DIR"

echo "========================================="
echo " <PKG_NAME> Training"
echo " User:          $USER"
echo " Node:          $(hostname)"
echo " CPUs:          $SLURM_CPUS_PER_TASK"
echo " GPUs:          $N_GPUS"
echo " Job ID:        $SLURM_JOB_ID"
echo " Model:         <MODEL_NAME>"
echo " Architecture:  ${N_LAYER}L (${N_LAYER_BEGIN}+mid*${N_REPEAT}+${N_LAYER_END})"
echo " Iterations:    $ITERATIONS"
echo " Eff. BS:       $((BATCH_SIZE * ACC_STEPS))"
echo " Checkpoint:    every $CKPT_FREQ steps -> $EXPS_DIR"
echo " Data dir:      $DATA_DIR"
echo " Started:       $(date)"
echo "========================================="

# --- Environment ---
module load conda
eval "$(conda shell.bash hook)"
conda activate "$CONDA_ENV_PREFIX"

# WandB offline (compute nodes have no internet)
export WANDB_MODE=offline

# NCCL: force Simple protocol to avoid LL-protocol hangs during DDP
# checkpoint coordination (see reprod-notes B9)
export NCCL_PROTO=Simple

cd "$REPO_DIR"

# --- GPU diagnostics ---
echo ""
echo "GPU Info:"
nvidia-smi --query-gpu=index,name,memory.total,driver_version --format=csv,noheader
echo ""

# --- Verify dataset exists ---
if [ ! -f "$DATA_DIR/openwebtext2/train.bin" ]; then
    echo "ERROR: Dataset not found at $DATA_DIR/openwebtext2/train.bin"
    echo "  Run: bash iridis/download-dataset/job.sh"
    echo "  Then: bash iridis/extract-tokenize-dataset/job.sh"
    exit 1
fi

# --- Build training args ---
TRAIN_ARGS=(
    # --- Config format ---
    --config_format base          # Which config parser to use (only "base" exists)

    # --- Architecture ---
    --model <MODEL_NAME>          # Model class from models/__init__.py
    --n_embd 768                  # Hidden dimension (paper: 768 for all models)
    --n_head 12                   # Attention heads (paper: 12 for all models)
    --n_layer "$N_LAYER"          # Number of transformer layers per block
    --n_repeat "$N_REPEAT"        # How many times the block is repeated (CoT depth)
    --n_layer_begin "$N_LAYER_BEGIN"  # Prefix layers NOT repeated (0 for Table 1)
    --n_layer_end "$N_LAYER_END"     # Suffix layers NOT repeated (0 for Table 1)

    # --- Training hyperparameters ---
    --batch_size "$BATCH_SIZE"    # Per-GPU micro-batch size (tokens per forward pass)
    --sequence_length 256         # Context window length (paper: 256)
    --acc_steps "$ACC_STEPS"      # Gradient accumulation steps before optimizer update
    --dropout 0.0                 # Dropout rate (paper: 0.0 for all models)
    --iterations "$ITERATIONS"    # Total training steps
    --lr 1e-3                     # Peak learning rate for OneCycleLR (paper: 0.001)
    --weight_decay 0.1            # AdamW weight decay
    --warmup_percent 0.2          # Fraction of steps for LR warmup (0.2 * 40k = 8000)
    --seed "$SEED"                # RNG seed for reproducibility

    # --- Dataset ---
    --dataset owt2                # Dataset name (determines subdir in data_dir)
    --data_dir "$DATA_DIR"        # Parent dir containing owt2/train.bin and owt2/val.bin
    --data_in_ram                 # Load full dataset into RAM (faster, needs ~16 GB)

    # --- Checkpointing and output ---
    --save_checkpoint_freq "$CKPT_FREQ"  # Save ckpt_<step>.pt every N steps
    --results_base_folder "$EXPS_DIR"    # Root for checkpoint tree (see path note above)
    --exp_name "$EXP_NAME"        # Explicit experiment name (avoids auto-generated mess)
    --use_pretrained auto         # On resubmit: scan for latest ckpt and resume from it
    --eval_freq 100               # Run validation every N steps

    # --- Logging ---
    --wandb                       # Enable Weights & Biases logging
    --wandb_project rcotformer    # WandB project name

    # --- Model-specific args (uncomment ONLY for models that use them) ---
    # cotformer_full_depth IGNORES these three; cotformer_full_depth_lnmid_depthemb
    # USES them. Including unused args pollutes the auto-generated exp_name.
    # --depth_random_method uniform_random_range  # How to sample repeat depth during training
    # --min_repeat "$N_REPEAT"                    # Minimum repeats when using random depth
    # --depth_embedding linear_learned            # Learned embedding indicating current repeat

    "$@"                          # Pass-through args from the command line
)

# --- Launch ---
if [ "$N_GPUS" -gt 1 ]; then
    export OMP_NUM_THREADS=1
    RDZV_HOST=$(hostname)
    RDZV_PORT=$(expr 10000 + $(echo -n "$SLURM_JOB_ID" | tail -c 4))

    echo "Launching DDP training: ${N_GPUS} GPUs, RDZV ${RDZV_HOST}:${RDZV_PORT}"
    torchrun \
        --nproc_per_node="$N_GPUS" \
        --rdzv_backend=c10d \
        --rdzv_endpoint="${RDZV_HOST}:${RDZV_PORT}" \
        main.py "${TRAIN_ARGS[@]}" \
        --distributed_backend nccl
else
    echo "Launching single-GPU training"
    python main.py "${TRAIN_ARGS[@]}"
fi

EXIT_CODE=$?

echo "========================================="
echo " Training finished: $(date)"
echo " Exit code: $EXIT_CODE"
echo ""
echo " Checkpoints: $EXPS_DIR/owt2/<MODEL_NAME>/$EXP_NAME"
echo ""
echo " If training incomplete, resubmit:"
echo "   bash iridis/<PKG_NAME>/job.sh"
echo ""
echo " After training completes, sync WandB:"
echo "   wandb sync $WANDB_DIR/<offline-run-*>"
echo "========================================="

exit $EXIT_CODE
